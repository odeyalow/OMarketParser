[Unit]
Description=OMarket Parser
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/omarket-parser
Environment=PORT=5050
Environment=GUNICORN_WORKERS=1
ExecStart=/opt/omarket-parser/run_ui.sh
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target

